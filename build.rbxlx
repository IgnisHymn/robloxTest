				e = entities[i_u]
				entities_u = entities
				local columns_map = archetype.columns_map
				columns_map_u = columns_map
				col0 = columns_map[id0]
				col1 = columns_map[id1]
				col2 = columns_map[id2]
				col3 = columns_map[id3]
				col0_u = col0
				col1_u = col1
				col2_u = col2
				col3_u = col3
			end

			local row = i_u
			i_u -= 1

			return e, col0[row], col1[row], col2[row], col3[row]
